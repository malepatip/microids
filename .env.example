# Home Assistant
HA_URL=http://localhost:8123
HA_TOKEN=your_long_lived_access_token

# Cloudflare Access (optional, for remote HA behind Cloudflare)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Groq (free tier at console.groq.com)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL_ID=llama-3.3-70b-versatile

# AWS Bedrock (optional, alternative to Groq)
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_AWS_PROFILE=default
AWS_REGION=us-east-1

# Remote server (optional, for server-side execution)
MICROIDS_SERVER_URL=https://your-server.example.com/microids
